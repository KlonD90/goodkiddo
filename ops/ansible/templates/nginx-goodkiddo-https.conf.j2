server {
    listen 80;
    listen [::]:80;
    server_name {{ bot_main_domain }} {{ bot_app_domain }};

    location ^~ /.well-known/acme-challenge/ {
        root {{ bot_acme_webroot }};
        default_type "text/plain";
        try_files $uri =404;
    }

    location / {
        return 301 https://$host$request_uri;
    }
}

server {
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
    server_name {{ bot_main_domain }};

    ssl_certificate /etc/letsencrypt/live/{{ bot_main_domain }}/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/{{ bot_main_domain }}/privkey.pem;
    ssl_session_cache shared:goodkiddo_ssl:10m;
    ssl_session_timeout 1d;

    root {{ bot_landing_dir }};
    index index.html;

    location / {
        try_files $uri $uri/ /index.html;
    }
}

server {
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
    server_name {{ bot_app_domain }};

    ssl_certificate /etc/letsencrypt/live/{{ bot_main_domain }}/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/{{ bot_main_domain }}/privkey.pem;
    ssl_session_cache shared:goodkiddo_ssl:10m;
    ssl_session_timeout 1d;

    location /assets/ {
        root {{ bot_web_dist_dir }};
        expires 30d;
        add_header Cache-Control "public, immutable";
    }

    location /fs/ {
        root {{ bot_web_dist_dir }};
        try_files $uri $uri/ /fs/index.html;
    }

    location /api/fs/ {
        proxy_pass http://127.0.0.1:{{ web_port | default(8083) }};
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto https;
        proxy_set_header X-Real-IP $remote_addr;
    }

    location /_dl {
        proxy_pass http://127.0.0.1:{{ web_port | default(8083) }};
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto https;
        proxy_set_header X-Real-IP $remote_addr;
    }

    location / {
        return 404;
    }
}
