{
	"compilerOptions": {
		"lib": ["DOM", "ESNext"],
		"module": "ESNext",
		"moduleResolution": "bundler",
		"target": "ESNext",
		"jsx": "react-jsx",
		"allowImportingTsExtensions": true,
		"noEmit": true,
		"strict": true,
		"skipLibCheck": true,
		"allowSyntheticDefaultImports": true,
		"esModuleInterop": true,
		"types": ["bun"]
	},
	"include": ["**/*.ts", "**/*.tsx"]
}
